# Copy this file to .env and adjust values as needed
# cp .env.example .env

# Database (SQLite by default — change to PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./jobs.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/job_processor

# Job processing simulation
JOB_MIN_DELAY=5        # Minimum simulated delay in seconds
JOB_MAX_DELAY=10       # Maximum simulated delay in seconds
JOB_FAILURE_RATE=0.1   # 10% chance of random failure (0.0 to 1.0)
